# ============================================================
# TPS Grading Portal — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------ DATABASE ------
# Option A: Local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/tps_grading"
#
# Option B: Neon (recommended for zero-setup cloud Postgres — free tier available)
# Get URL from: https://neon.tech → New Project → Connection string
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/tps_grading?sslmode=require"
#
# Option C: Supabase
# Get URL from: https://supabase.com → Project Settings → Database → Connection string (URI)
# DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

DATABASE_URL=""

# ------ AUTH.JS (Admin Session) ------
# Generate a strong random secret:  openssl rand -base64 32
AUTH_SECRET=""

# ------ APP URL ------
# Local development
NEXTAUTH_URL="http://localhost:3000"
# Production — set to your deployed domain
# NEXTAUTH_URL="https://your-domain.com"

# ------ OPTIONAL: Pin salt rounds (default 12) ------
# BCRYPT_ROUNDS=12
