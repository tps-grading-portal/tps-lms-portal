# ============================================================
# TPS LMS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------ DATABASE ──────────────────────────────────────────────────────────────
# Option A: Neon (recommended — free tier, zero-setup)
#   Get URL: https://neon.tech → New Project → Connection string
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/tps_lms?sslmode=require"
#
# Option B: Local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/tps_lms"
#
# Option C: Azure Government PostgreSQL (production)
# DATABASE_URL="postgresql://user:pass@server.postgres.database.azure.us/tps_lms?sslmode=require"

DATABASE_URL=""

# ------ AUTH.JS (Session Security) ────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
# This signs all JWT session tokens — changing it logs everyone out.
AUTH_SECRET=""

# ------ APP URL ───────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://your-vercel-domain.vercel.app"

# ------ FILE STORAGE ──────────────────────────────────────────────────────────
# Controls where uploaded Content Vault files are stored.
# Options: VERCEL_BLOB (default), AZURE_BLOB, LOCAL
STORAGE_PROVIDER=VERCEL_BLOB

# Required when STORAGE_PROVIDER=VERCEL_BLOB (get from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=""

# Required when STORAGE_PROVIDER=AZURE_BLOB (fill in when Azure credentials available)
# AZURE_STORAGE_CONNECTION_STRING=""
# AZURE_STORAGE_CONTAINER="tps-vault"

# ------ GOOGLE SHEETS (Flight Schedule) ───────────────────────────────────────
# Read-only integration. Get API key from Google Cloud Console:
#   APIs & Services → Credentials → Create API Key → restrict to Sheets API
# Sheet ID: 1m5-6FxgCpgjlbcYYXlFMXrJ0sgyBPFwql9sG7WDI1MU
GOOGLE_SHEETS_API_KEY=""

# ------ OPTIONAL ──────────────────────────────────────────────────────────────
# Bcrypt rounds for password hashing (default 12)
# BCRYPT_ROUNDS=12

# Node environment (set automatically by Vercel/Next.js)
# NODE_ENV=development
