// TPS Grading Portal — Prisma Schema v2
// PostgreSQL + Prisma 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ADMIN
// ============================================================

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  @@map("admin_users")
}

// ============================================================
// CLASSES & ACCESS CONTROL
// ============================================================

model Class {
  id         String    @id @default(cuid())
  name       String    @unique
  isActive   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  access            ClassAccess[]
  students          Student[]
  sessions          GradingSession[]
  studentSurveys    StudentSurveyResponse[]
  instructorSurveys InstructorSurveyResponse[]
  surveyTemplates   SurveyQuestionTemplate[]
  criteria          Criterion[]           // class-specific frozen snapshot

  @@map("classes")
}

model ClassAccess {
  id           String     @id @default(cuid())
  classId      String
  role         AccessRole
  passwordHash String
  updatedAt    DateTime   @updatedAt

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, role])
  @@map("class_access")
}

enum AccessRole {
  GRADER
  PANEL_CHAIR
}

// ============================================================
// STAFF MEMBERS (global)
// ============================================================

model StaffMember {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  assessments GraderAssessment[]

  @@map("staff_members")
}

// ============================================================
// SCENARIOS — global, permanent, sequential numbers
// Scenario 1 always means the same scenario forever.
// ============================================================

model Scenario {
  id       String  @id @default(cuid())
  number   Int     @unique  // globally unique, never reused
  label    String           // e.g. "Scenario 1"
  isActive Boolean @default(true)

  sessions GradingSession[]

  @@map("scenarios")
}

// ============================================================
// RUBRIC CRITERIA
// classId = null  → global template (admin edits these)
// classId = <id>  → frozen snapshot for that class
// sortOrder is unique within scope (enforced in app layer)
// ============================================================

model Criterion {
  id             String  @id @default(cuid())
  code           String  // e.g. "1.1" — unique within classId scope
  pillar         Pillar
  name           String
  weight         Float   // must sum to 1.0 within scope
  outcomesRefs   String
  description    String  @db.Text
  waaDescriptor  String  @db.Text
  avgDescriptor  String  @db.Text
  failDescriptor String  @db.Text
  sortOrder      Int
  isActive       Boolean @default(true)
  classId        String? // null = global template; set = frozen for this class

  class  Class?          @relation(fields: [classId], references: [id], onDelete: Cascade)
  grades CriterionGrade[]

  @@map("criteria")
}

enum Pillar {
  TESTER
  LEADER
  THINKER
}

// ============================================================
// STUDENTS  (identified by number, never by name)
// Displayed as "{class.name}-{number}", e.g. "26A-7"
// ============================================================

model Student {
  id        String   @id @default(cuid())
  classId   String
  number    Int      // integer part, e.g. 1, 2, 3 … N
  track     Track
  createdAt DateTime @default(now())

  class    Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  sessions GradingSession[]

  @@unique([classId, number])
  @@map("students")
}

enum Track {
  PILOT
  RPA
  FTE
  OPERATOR
  CSO_WSO
  ABM
}

// ============================================================
// GRADING SESSIONS
// ============================================================

model GradingSession {
  id             String        @id @default(cuid())
  classId        String
  studentId      String
  scenarioId     String
  status         SessionStatus @default(OPEN)
  finalScore     Float?        // calculated weighted average
  // Official output score — for a passing retake this is capped at exactly 70.0
  outputScore    Float?
  hasFail        Boolean       @default(false)
  // Retake tracking
  isRetake       Boolean       @default(false)
  retakeSourceId String?       // FK to the original failed session
  createdAt      DateTime      @default(now())
  finalizedAt    DateTime?

  class        Class              @relation(fields: [classId], references: [id])
  student      Student            @relation(fields: [studentId], references: [id])
  scenario     Scenario           @relation(fields: [scenarioId], references: [id])
  assessments  GraderAssessment[]
  retakeSource GradingSession?    @relation("RetakeSessions", fields: [retakeSourceId], references: [id])
  retakes      GradingSession[]   @relation("RetakeSessions")

  @@map("grading_sessions")
}

enum SessionStatus {
  OPEN
  PENDING_RESOLUTION
  READY_TO_FINALIZE
  FINALIZED
}

// ============================================================
// GRADER ASSESSMENTS
// ============================================================

model GraderAssessment {
  id            String    @id @default(cuid())
  sessionId     String
  staffMemberId String
  weightedSum   Float?
  hasFail       Boolean   @default(false)
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())

  session     GradingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staffMember StaffMember      @relation(fields: [staffMemberId], references: [id])
  grades      CriterionGrade[]

  @@unique([sessionId, staffMemberId])
  @@map("grader_assessments")
}

// ============================================================
// CRITERION GRADES
// ============================================================

model CriterionGrade {
  id              String     @id @default(cuid())
  assessmentId    String
  criterionId     String
  gradeValue      Int
  originalValue   Int?
  isDiscontinuity Boolean    @default(false)
  editedBy        EditSource?
  editedAt        DateTime?
  submittedAt     DateTime   @default(now())

  assessment GraderAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  criterion  Criterion        @relation(fields: [criterionId], references: [id])

  @@unique([assessmentId, criterionId])
  @@map("criterion_grades")
}

enum EditSource {
  GRADER
  PANEL_CHAIR
}

// ============================================================
// SURVEYS
// ============================================================

model SurveyQuestionTemplate {
  id           String       @id @default(cuid())
  surveyType   SurveyType
  classId      String?
  sortOrder    Int
  questionKey  String
  questionText String       @db.Text
  questionType QuestionType
  options      Json?
  isRequired   Boolean      @default(true)
  isActive     Boolean      @default(true)

  class Class? @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("survey_question_templates")
}

enum SurveyType {
  STUDENT
  INSTRUCTOR
}

enum QuestionType {
  TEXT
  MULTIPLE_CHOICE
  MULTI_SELECT
  LIKERT
  DATE
  NUMBER
}

model StudentSurveyResponse {
  id          String   @id @default(cuid())
  classId     String
  responses   Json
  submittedAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id])

  @@map("student_survey_responses")
}

model InstructorSurveyResponse {
  id          String   @id @default(cuid())
  classId     String
  responses   Json
  submittedAt DateTime @default(now())

  class Class @relation(fields: [classId], references: [id])

  @@map("instructor_survey_responses")
}
